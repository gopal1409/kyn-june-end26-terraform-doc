##lets create a new map varaible file a15.automaker.tf
  variable "suzuki" {
  description = "type of auto"
  type = map(string)
  default = {
    "vitara" = "maruti"
    "wagonr" = "maruti"
    
  }
}

##lets modify the nic 
  #when we create a nic card in starting add the for_each loop

resource "azurerm_network_interface" "web_nic" {
  for_each = var.suzuki
    depends_on = [azurerm_public_ip.web_vm_publiip]
   name                = "${local.resource_name_prefix}-nic${each.key}" #in the name add the each.key so that all the nic card will be created with unique name
  location            = azurerm_resource_group.myrg.location
  resource_group_name = azurerm_resource_group.myrg.name

  ip_configuration {
    name                          = "internal"
    subnet_id                     = azurerm_subnet.web-subnet.id
    private_ip_address_allocation = "Dynamic"
   #public_ip_address_id          = azurerm_public_ip.web_vm_publiip.id #disable the public ip we will use lb to transfer traffic to this instance
  }
}

#lets modify the a11.linux.vm.tf 
  #1. add the for each loop
  resource "azurerm_linux_virtual_machine" "web_vm" {
  for_each = var.suzuki #add this loop
   name                = "${local.resource_name_prefix}-vm${each.key}" #add the each.key at the end
  location            = azurerm_resource_group.myrg.location
  resource_group_name = azurerm_resource_group.myrg.name
  size                = var.vm_size["prod"]
  admin_username      = "azureuser"
  network_interface_ids = [
    azurerm_network_interface.web_nic[each.key].id, #inside the nic card also add the each.key field
  ]

  admin_ssh_key {
    username   = "azureuser"
    public_key = file("${path.module}/ssh-keys/terraform-azure.pem.pub")
    #path.module will ensure that it is looking for a file in the current module directory"
  }

  os_disk {
    caching              = "ReadWrite"
    storage_account_type = "Standard_LRS"
  }

  source_image_reference {
    publisher = "Canonical"
    offer     = "0001-com-ubuntu-server-jammy"
    sku       = "22_04-lts"
    version   = "latest"
  }

  #finally do terraform apply and check in the portal two instance are created or not
  custom_data = filebase64("${path.module}/app/app.sh")
  tags = local.project_lucky
}

#lets create the load balancer 
#create a new file a16.lb.tf
#first we will create an lb
resource "azurerm_lb" "web_lb" {
  name                = "${local.resource_name_prefix}-weblb"
  location            = azurerm_resource_group.myrg.location
  resource_group_name = azurerm_resource_group.myrg.name

  frontend_ip_configuration {
    name                 = "PublicIPAddress"
    public_ip_address_id = azurerm_public_ip.web_vm_publiip.id
  }
}
#create the backend pool for lb
resource "azurerm_lb_backend_address_pool" "web_lb_pool" {
  loadbalancer_id = azurerm_lb.web_lb.id    
  name            = "${local.resource_name_prefix}-weblbpool"
}

#lb probe

#lb rule

#finally attach the nic card with pool
#then do terraform apply verify the lb is created inside your resource group and backend pool is also created

#lets update the  file a16.lb.tf and add probe rule and backend attachment 
#lb probe
resource "azurerm_lb_probe" "web_lb_probe" {
  loadbalancer_id     = azurerm_lb.web_lb.id #this probe will be attached with lb rule
  name                = "${local.resource_name_prefix}-weblbprobe"
  protocol            = "Tcp"
  port                = 80
  #protocol = "Http"
  #request_path = "/var/www/html/index.html"
  interval_in_seconds = 30  #every 30 second it will ping your port 80
  number_of_probes    = 2 #two time it will ping your port 80 if it is not responding then it will mark the vm as unhealthy
}

#lb rule
resource "azurerm_lb_rule" "web_lb_rule" {
  loadbalancer_id            = azurerm_lb.web_lb.id
  name                       = "${local.resource_name_prefix}-weblbrule"
  protocol                   = "Tcp"
  frontend_port              = 80 #the port of your lb 443
  backend_port               = 80 #tomcat 8080
  frontend_ip_configuration_name = azurerm_lb.web_lb.frontend_ip_configuration[0].name
  backend_address_pool_ids   = [azurerm_lb_backend_address_pool.web_lb_pool.id]
  probe_id                   = azurerm_lb_probe.web_lb_probe.id
}

#finally attach the nic card with pool
resource "azurerm_network_interface_backend_address_pool_association" "web_nic_lb_association" {
  for_each = var.suzuki 
  network_interface_id    = azurerm_network_interface.web_nic[each.key].id
  ip_configuration_name   = azurerm_network_interface.web_nic[each.key].ip_configuration[0].name
  backend_address_pool_id = azurerm_lb_backend_address_pool.web_lb_pool.id
}

